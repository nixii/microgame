
let m1 load_mesh "assets/test.obj"

let e1 new "entity" with

    set position 0 0 5
    attach new "mesh" from m1

end

let time 0
let dir 1

on frame with dt do
    let time time + (dt * dir * 5)

    if time > 10 do
        let dir -1
    end

    if time < 0 do
        let dir 1
    end

    as e1 do
        as get position do
            set x (5 - time)
            echo get x
        end
    end
end
