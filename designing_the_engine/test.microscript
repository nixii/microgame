new entity with
    echo "hi"

    set position 1 1 1
    let pos get position
    echo "set position to " pos

    set rotation 45 45 45
    let rot get rotation
    echo "set rotation to " rot

    set scale 3 3 3
    let scale get scale
    echo "set scale to " scale

    attach new collider with
        let size 5 5 5
        echo "collider made!"
        set size size
    end
    echo "collider attached"
end

set light_direction 0 1 0
let ld get light_direction
echo "light is going (opposite) of <" ld ">!"