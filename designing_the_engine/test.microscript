
let SPEED 5

let m1 load_mesh "assets/test.obj"

let e1 new "entity" with

    set position 0 0 5
    attach new "mesh" from m1

end

let time 0

on frame with dt do
    let time time + dt

    let movement 0
    if (call is_key_down "w") do
        let movement movement + SPEED
    end

    if (call is_key_down "s") do
        let movement movement - SPEED
    end

    as e1 do
        as get position do
            set y (get y) + (movement * dt)
        end
    end
end
