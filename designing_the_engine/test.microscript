
let m1 load_mesh "assets/test.obj"s

let e1 new "entity" with
    set position 0 -5 5

    attach new "mesh" from m1 with
        set color 200 200 255
    end
end

let time 0

on frame with dt do
    let time time + dt

    # update position
    as e1 do

        # calcualte the new pos
        let newx (call cos (time)) * 5
        let newy (call sin (time)) * 5

        # set the position
        let newpos as get position do
            set x newx
            set y newy
        end

        set position newpos
        
    end
end