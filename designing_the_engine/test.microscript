
let m1 load_mesh "assets/cube.obj"

let e1 new "entity" with
    set position 0 0 5

    attach new "mesh" from m1 with
        set color 200 200 255
    end
end

let time 1
let can false

on frame with dt do

    let md call get_mouse_delta
    as md let mdx (get x) / 240
    as md let mdy (get y) / -240

    if can do
        as e1 do
            let p get position
            let p as p do
                set x (get x) + mdx
                set y (get y) + mdy
            end
            set position p
        end
    end

    if (mdy > 1) | (mdy < -1) do
        let can true
    end
end