
let SPEED 5

let m1 load_mesh "assets/test.obj"

let e1 new "entity" with

    set position 0 0 5
    attach new "mesh" from m1

end

let time 0

on frame with dt do
    let time time + dt

    let movement 0 0 0
    if (call is_key_down "w") do
        as movement do
            set y (get y) + SPEED
        end
    end

    if (call is_key_down "s") do
        as movement do
            set y (get y) - SPEED
        end
    end

    if (call is_key_down "a") do
        as movement do
            set x (get x) - SPEED
        end
    end

    if (call is_key_down "d") do
        as movement set x (get x) + SPEED
    end
    echo movement

    as e1 do
        let p get position

        set position p + (movement * dt)
    end
end
